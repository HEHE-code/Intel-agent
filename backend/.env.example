# ===== 情报智能体生成器 · 环境变量 =====
# 复制本文件为 .env 并填入你的 Key。只有 LLM Key 必填，数据源全是免 Key 免费源。

# ---------- LLM（必填其一，系统自动识别你填了哪个） ----------
# DeepSeek：https://platform.deepseek.com/ 申请
DEEPSEEK_API_KEY=

# GLM（智谱）：https://open.bigmodel.cn/ 申请
ZHIPU_API_KEY=
GLM_API_KEY=

# ---------- LLM 选型（可选，默认按 Key 自动选） ----------
# 显式指定：deepseek | glm
LLM_PROVIDER=

# ---------- 数据源（全部免 Key 免费源，以下为可选升级） ----------
# 有 Tavily Key 则用它替代 DuckDuckGo（质量更好，1000 次/月免费）
TAVILY_API_KEY=
# 有 Alpha Vantage Key 则补充金融数据（25 次/天免费）
ALPHA_VANTAGE_API_KEY=
# 有 NewsAPI Key 则补充新闻（仅限本机自用）
NEWSAPI_KEY=

# ---------- 运行配置 ----------
# SQLite 数据库路径（默认 backend/data/intelligence.db）
DATABASE_PATH=data/intelligence.db
# 允许跨域的前端地址（开发期前端跑在 3000 端口）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
